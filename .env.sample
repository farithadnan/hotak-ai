# ── Required ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# ── Auth (change in production!) ────────────────────────────────────────────
JWT_SECRET_KEY=change-this-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# ── Admin bootstrap (applied on first run only) ─────────────────────────────
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=change-this-password
ADMIN_BOOTSTRAP_EMAIL=admin@localhost

# ── CORS (comma-separated origins) ──────────────────────────────────────────
# Dev: http://localhost:5173  |  Docker: http://localhost
CORS_ORIGINS=http://localhost:5173

# ── Frontend build (Docker only) ─────────────────────────────────────────────
# URL the browser uses to reach the backend API.
# Local Docker: http://localhost:8000  |  Remote: http://your-server:8000
VITE_API_BASE_URL=http://localhost:8000

# ── Optional tunables (defaults shown) ──────────────────────────────────────
LLM_MAX_TOKENS=4096
STREAM_MAX_CHARS=32000
ENABLE_SUMMARY_MEMORY=true
RETRIEVAL_K=5
LOG_LEVEL=INFO

# ── LangSmith tracing (optional) ────────────────────────────────────────────
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=Hotak AI